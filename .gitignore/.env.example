# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/edutrack
# MongoDB Atlas (replace with your connection string):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/edutrack

# ── JWT ────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Since frontend is served from the same server, you can leave this blank
# or add external origins if needed
ALLOWED_ORIGINS=http://localhost:5000
